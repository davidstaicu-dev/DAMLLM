{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "circuit": { 
      "enum": ["Prado Rosquilla", "Cataratas Yoshi", "Barranco Goloso", "Fábrica de Toad"] 
    },
    "Classificació": {
      "type": "array",
      "minItems": 2,
      "maxItems": 20,
      "items": {
        "type": "object",
        "properties": {
          "posició": { "type": "integer", "minimum": 1, "maximum": 20 },
          "nick-player": { "type": "string" },
          "personatge": { "type": "string" },
          "color": { "enum": ["blanc", "negre", "groc", "blau", "roig", "verd", "taronja", "lila", "rosa"] },
          "Temps": { "type": "string", "pattern": "^[0-9]{2}:[0-9]{2}$" },
          "voltes": { "type": "integer", "minimum": 0, "maximum": 5 },
          "Accidents": { "type": "integer" },
          "Nitros": { "type": "integer" },
          "Rookie": { "enum": ["Si", "No"] }
        },
        "required": ["posició", "nick-player", "personatge", "Temps", "voltes", "Accidents"]
      }
    }
  },
  "required": ["Classificació"]
}